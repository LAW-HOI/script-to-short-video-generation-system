{
  "submit_url": "https://your-digital-human-api.example.com/v1/jobs",
  "method": "POST",
  "request_mode": "form",
  "headers": {
    "Authorization": "Bearer ${DIGITAL_HUMAN_API_KEY}"
  },
  "payload_template": {
    "title": "${title}",
    "script": "${script}",
    "avatar_type": "photo",
    "voice_mode": "upload"
  },
  "files_template": {
    "avatar_image": "${avatar_file_path}",
    "audio_file": "${audio_file_path}"
  },
  "job_id_field": "data.job_id",
  "status_url": "https://your-digital-human-api.example.com/v1/jobs/${job_id}",
  "status_field": "data.status",
  "done_values": [
    "completed",
    "success"
  ],
  "error_values": [
    "failed",
    "error"
  ],
  "result_url_field": "data.video_url",
  "poll_interval": 8
}
