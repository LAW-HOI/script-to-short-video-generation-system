{
  "submit_url": "https://your-image-api.example.com/v1/images",
  "method": "POST",
  "headers": {
    "Authorization": "Bearer ${AVATAR_API_KEY}",
    "Content-Type": "application/json"
  },
  "payload_template": {
    "prompt": "${avatar_prompt}",
    "size": "1024x1024"
  },
  "image_url_field": "data.url"
}
