# Copy this file to .env and fill in your local keys.
# .env is intentionally ignored by git and should not be shared.

GEMINI_API_KEY=your_gemini_api_key
PEXELS_API_KEY=your_pexels_api_key

# Optional: keep Tencent credentials here too if you do not want to enter them in the web UI.
TENCENT_DH_APPKEY=your_tencent_appkey
TENCENT_DH_ACCESS_TOKEN=your_tencent_access_token
TENCENT_DH_VIRTUALMAN_KEY=your_tencent_virtualman_key

# Optional: local Whisper/whisper.cpp model path for precise subtitles.
WHISPER_MODEL_PATH=/absolute/path/to/ggml-base.bin
